{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDECODE": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ZOXIDE": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(powershell.exe:*)",
      "Bash(pwsh:*)",
      "Bash(pwsh.exe:*)",
      "Bash(wsl:*)",
      "Bash(chmod:*)",
      "Bash(mkdir -p:*)",
      "Bash(bun run:*)",
      "Bash(bdg:*)",
      "Bash(claude mcp add:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ag:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(bat:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(http:*)",
      "mcp__pw-fast__browser_navigate",
      "mcp__pw-fast__browser_click",
      "mcp__pw-fast__browser_snapshot",
      "mcp__pw-fast__browser_wait_for",
      "mcp__pw-fast__browser_type",
      "mcp__pw-fast__browser_resize",
      "mcp__pw-fast__browser_close",
      "mcp__pw-fast__browser_evaluate",
      "mcp__pw-fast__browser_network_requests",
      "mcp__pw-fast__browser_batch_execute",
      "mcp__pw-fast__browser_take_screenshot",
      "mcp__pw-fast__browser_tab_list",
      "mcp__pw-fast__browser_tab_new",
      "mcp__pw-fast__browser_tab_select",
      "mcp__pw-fast__browser_find_elements",
      "mcp__pw-fast__browser_hover",
      "mcp__pw-fast__browser_drag",
      "mcp__pw-fast__browser_press_key",
      "mcp__pw-fast__browser_select_option",
      "mcp__pw-fast__browser_file_upload",
      "mcp__pw-fast__browser_handle_dialog",
      "mcp__pw-fast__browser_inspect_html",
      "mcp__pw-fast__browser_console_messages",
      "mcp__pw-fast__browser_diagnose",
      "mcp__pw-fast__browser_install",
      "mcp__pw-fast__browser_navigate_back",
      "mcp__pw-fast__browser_navigate_forward",
      "mcp__pw-fast__browser_tab_close",
      "Bash(claude mcp list:*)",
      "Bash(xargs:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(id:*)",
      "Bash(whoami:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(bw-inject:*)",
      "Bash(bw-fetch search:*)",
      "Bash(bw-fetch meta:*)",
      "Skill",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getJiraIssueRemoteIssueLinks",
      "mcp__atlassian__getJiraIssueTypeMetaWithFields",
      "mcp__atlassian__getJiraProjectIssueTypesMetadata",
      "mcp__atlassian__getTransitionsForJiraIssue",
      "mcp__atlassian__getVisibleJiraProjects",
      "mcp__atlassian__lookupJiraAccountId",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__getConfluencePageDescendants",
      "mcp__atlassian__getConfluencePageFooterComments",
      "mcp__atlassian__getConfluencePageInlineComments",
      "mcp__atlassian__getConfluenceSpaces",
      "mcp__atlassian__getPagesInConfluenceSpace",
      "mcp__atlassian__searchConfluenceUsingCql",
      "ToolSearch",
      "TaskList",
      "TaskGet",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(just:*)",
      "Bash(uv:*)",
      "Bash(python3:*)",
      "Bash(lsof:*)",
      "Bash(pgrep:*)",
      "Bash(test:*)",
      "Bash(bash:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(bw:*)",
      "Bash(rclone:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(python .claude/hooks/validate-write-path.py electron/renderer)",
      "Bash(python .claude/hooks/validate-write-path.py electron/main electron/preload)",
      "Bash(python .claude/hooks/validate-write-path.py backend)"
    ],
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=* of=/dev/*:*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ~/.claude/ccnotify/ccnotify.py Notification"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/damage-control/bash-tool-damage-control.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/damage-control/edit-tool-damage-control.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/damage-control/write-tool-damage-control.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ~/.claude/ccnotify/ccnotify.py Stop"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "__claudebar_hook() { PORT=$(cat \"$HOME/.claude/claudebar-hook-port\" 2>/dev/null || echo 19847); cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project ~/.claude/ccnotify/ccnotify.py UserPromptSubmit"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "uv run ~/.claude/status_lines/status_line.py",
    "padding": 0
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "voiceEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "haiku"
}
