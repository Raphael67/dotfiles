# rclone - OAuth tokens and machine-local config
dotfiles/dot-config/rclone/rclone.conf

# glab CLI - recovery data may contain professional info
dotfiles/dot-config/glab-cli/recover/

# Docker - runtime state
dotfiles/dot-config/docker/buildx/
dotfiles/dot-config/docker/.token_seed
dotfiles/dot-config/docker/.token_seed.lock

# Homebrew - runtime state (trust-store lock; created in ~/.config/homebrew
# because XDG_CONFIG_HOME=~/.config, which is stow-symlinked into this repo)
dotfiles/dot-config/homebrew/trust.json.lock

# gitleaks - private forbidden-terms list (company/project names kept out of
# this public repo). The .example template IS committed; the real file is not.
.forbidden-terms.toml

# GitNexus - machine-local repo paths (private). The .example is committed.
scripts/setup-gitnexus.local

# Python bytecode
__pycache__/
*.pyc
