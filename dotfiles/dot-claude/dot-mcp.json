{
    "mcpServers": {
        "mcp-ical": {
            "command": "uv",
            "args": [
                "--directory",
                "/Users/raphael/.local/share/mcp-servers/mcp-ical",
                "run",
                "mcp-ical"
            ]
        },
        "pw-fast": {
            "command": "npx",
            "args": [
                "@tontoko/fast-playwright-mcp@latest",
                "--headless"
            ]
        },
        "atlassian": {
            "type": "sse",
            "url": "https://mcp.atlassian.com/v1/sse"
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ]
        }
    }
}
