# Ghostty Configuration
# Translated from WezTerm configuration

# Theme and Colors
theme = catppuccin-macchiato

# Font Configuration
font-family = JetBrains Mono
font-size = 16

# Window Configuration
# window-decoration = false
window-padding-x = 5
window-padding-y = 5
background-opacity = 1.0
# Cursor Configuration
cursor-style = bar
cursor-style-blink = true

# Link Configuration
link-url = true

# Misc Configuration
confirm-close-surface = false
auto-update = check

# Background blur (macOS specific)
background-blur = 30
macos-option-as-alt = false

# Keybinds
# Note: tmux auto-starts when Ghostty opens on macOS and WSL.
# To open Ghostty without tmux:
# - From tmux: prefix + N (Ctrl+x N)
# - From shell: notmux (alias) — sets NO_TMUX=1 before launching zsh
# - From anywhere: global shortcut via macOS Shortcuts app

# Alternative shell: Nushell
# Uncomment to use nushell instead of default shell
# command = /opt/homebrew/bin/nu
